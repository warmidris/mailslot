#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TSX_BIN="$ROOT_DIR/node_modules/.bin/tsx"

if [[ ! -x "$TSX_BIN" ]]; then
  echo "Missing runtime dependencies. Run: npm install" >&2
  exit 1
fi

exec "$TSX_BIN" "$ROOT_DIR/scripts/stackmail-cli.mjs" "$@"
